# UdhariClub environment variables

# Supabase project URL (e.g. https://xxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon (public) key — safe to expose to the client
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — server only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# Public app URL used for invite links (e.g. https://udhari.club)
NEXT_PUBLIC_APP_URL=http://localhost:3000
